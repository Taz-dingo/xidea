{
  "name": "xidea-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm build:web",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "preview:web": "pnpm --dir apps/web preview",
    "dev:agent": "python -m xidea_agent",
    "install:agent": "python -m pip install -e ./apps/agent"
  }
}
