# === LLM 连接配置 ===
# 推荐：应用层统一只配这一组变量；接 GLM 时填官方 OpenAI-compatible 地址
XIDEA_LLM_API_KEY=
XIDEA_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
XIDEA_LLM_MODEL=glm-5

# 兼容回退：旧环境仍可使用这些变量，但不建议新配置继续依赖
# ZHIPU_API_KEY=
# ZAI_API_KEY=
# OPENAI_API_KEY=

# === LLM 行为配置 ===
XIDEA_LLM_TEMPERATURE=0.3
XIDEA_LLM_MAX_TOKENS=1200
XIDEA_LLM_FORCE_STREAM=false

# === 数据库配置 ===
# XIDEA_AGENT_DB_PATH=./data/xidea.db
