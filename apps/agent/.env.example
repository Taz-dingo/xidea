# === LLM 连接配置 ===
OPENAI_API_BASE=https://your-proxy.com/v1
OPENAI_API_KEY=sk-xxx
XIDEA_LLM_MODEL=gpt-4o

# === LLM 行为配置 ===
# wire API 模式: completions (兼容 GLM 等) 或 responses (OpenAI 新版)
XIDEA_LLM_WIRE_API=completions
XIDEA_LLM_TEMPERATURE=0.7
XIDEA_LLM_MAX_TOKENS=2048

# === 数据库配置 ===
# XIDEA_AGENT_DB_PATH=./data/xidea.db
